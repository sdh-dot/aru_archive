# Python
.venv/
.venv-*/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.pytest_tmp/
.mypy_cache/
.ruff_cache/

# 설정 (로컬 경로 포함)
config.json

# 로그
*.log
logs/

# 런타임 / 캐시
.runtime/
.thumbcache/
.cache/
.claude/

# SQLite DB (런타임 생성)
*.db
*.sqlite
*.sqlite3

# 로컬 아카이브 데이터 디렉터리
AruArchive/
Inbox/
Classified/
Managed/

# build 산출물 (install_host.bat / uninstall_host.bat / gen_manifest.py / aru_archive.spec 은 포함)
build/__pycache__/
build/*.exe
build/*.msi
build/*.zip
build/*.gif
build/pytest_tmp*/
build/runtime_probe*/
build/manual_warning_check/
# README 작업 보존용 로컬 patch 백업
build/readme-workingtree-before-main-sync.patch

# 설계 문서 (이진 파일 — 개인용)
docs/*.docx
# Notion 동기화용 로컬 feature spec
docs/feature_spec_notion.json

# Native Host 로컬 오버라이드
native_host/*.local.json

# Browser extension artifacts
browser-extension/**/node_modules/
browser-extension/**/dist/
browser-extension/**/*.crx
browser-extension/**/*.zip

# ===== Local research / diagnosis artifacts =====
mojibake_report*.json
repair_plan*.json

# ===== External-derived dataset samples =====
docs/data/**/*.sample.json
docs/data/**/full/
docs/data/**/raw/

# ===== Local research / scratch workspace =====
.research/
.scratch/

# ===== Tool smoke outputs =====
build/hitomi_catalog_check/
build/mojibake_*/

# ===== Local temporary/design workspace =====
temp/

# ===== Build artifacts =====
# Anchored with leading '/' so they only match the top-level build output dirs,
# not subpaths like docs/release/.
/dist/
/release/
